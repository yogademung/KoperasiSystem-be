  createdBy       String?       @map("CREATE_WHO") @db.VarChar(50)
  createdAt       DateTime      @default(now()) @map("CREATE_DATE")
  warehouseId     Int?          @map("WAREHOUSE_ID")
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  warehouse       Warehouse?    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@index([inventoryItemId])
  @@index([warehouseId], map: "t_stock_adjustment_WAREHOUSE_ID_fkey")
  @@map("t_stock_adjustment")
}

model PosShift {
  id           Int          @id @default(autoincrement()) @map("SHIFT_ID")
  userId       Int          @map("USER_ID")
  warehouseId  Int?         @map("WAREHOUSE_ID")
  terminalId   String?      @map("TERMINAL_ID") @db.VarChar(50)
  shiftDate    DateTime     @default(now()) @map("SHIFT_DATE")
  startTime    DateTime     @default(now()) @map("START_TIME")
  endTime      DateTime?    @map("END_TIME")
  status       String       @default("OPEN") @map("STATUS") @db.VarChar(20)
  startingCash Decimal      @default(0.0000) @map("STARTING_CASH") @db.Decimal(19, 4)
  endingCash   Decimal?     @map("ENDING_CASH") @db.Decimal(19, 4)
  totalSales   Decimal      @default(0.0000) @map("TOTAL_SALES") @db.Decimal(19, 4)
  journalId    Int?         @map("JOURNAL_ID")
  sales        PosSale[]
  user         User         @relation(fields: [userId], references: [id])
  warehouse    Warehouse?   @relation(fields: [warehouseId], references: [id])
  voidLogs     PosVoidLog[]

  @@index([userId])
  @@index([warehouseId])
  @@map("t_pos_shift")
}

model PosSale {
  id             Int           @id @default(autoincrement()) @map("SALE_ID")
  shiftId        Int           @map("SHIFT_ID")
  receiptNumber  String        @unique @map("RECEIPT_NO") @db.VarChar(50)
  saleDate       DateTime      @default(now()) @map("SALE_DATE")
  totalAmount    Decimal       @map("TOTAL_AMOUNT") @db.Decimal(19, 4)
  paymentMethod  String        @map("PAYMENT_METHOD") @db.VarChar(20)
  paymentAmount  Decimal       @map("PAYMENT_AMOUNT") @db.Decimal(19, 4)
  changeAmount   Decimal       @default(0.0000) @map("CHANGE_AMOUNT") @db.Decimal(19, 4)
  discountAmount Decimal       @default(0.0000) @map("DISCOUNT_AMOUNT") @db.Decimal(19, 4)
  discountNote   String?       @map("DISCOUNT_NOTE") @db.VarChar(200)
  status         String        @default("COMPLETED") @map("STATUS") @db.VarChar(20)
  createdBy      String?       @map("CREATE_WHO") @db.VarChar(50)
  shift          PosShift      @relation(fields: [shiftId], references: [id])
  items          PosSaleItem[]

  @@index([shiftId])
  @@map("t_pos_sale")
}

model PosSaleItem {
  id           Int        @id @default(autoincrement()) @map("SALE_ITEM_ID")
  saleId       Int        @map("SALE_ID")
  posProductId Int        @map("POS_PRODUCT_ID")
  quantity     Decimal    @map("QUANTITY") @db.Decimal(19, 2)
  unitPrice    Decimal    @map("UNIT_PRICE") @db.Decimal(19, 4)
  cogsPrice    Decimal    @map("COGS_PRICE") @db.Decimal(19, 4)
  totalPrice   Decimal    @map("TOTAL_PRICE") @db.Decimal(19, 4)
  createdBy    String?    @map("CREATE_WHO") @db.VarChar(50)
  posProduct   PosProduct @relation(fields: [posProductId], references: [id])
  sale         PosSale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([posProductId])
  @@map("t_pos_sale_item")
}

model PosVoidLog {
  id           Int        @id @default(autoincrement()) @map("VOID_ID")
  shiftId      Int        @map("SHIFT_ID")
  posProductId Int        @map("POS_PRODUCT_ID")
  quantity     Decimal    @map("QUANTITY") @db.Decimal(19, 2)
  reason       String     @map("REASON") @db.VarChar(200)
  createdBy    String?    @map("CREATE_WHO") @db.VarChar(50)
  createdAt    DateTime   @default(now()) @map("CREATE_DATE")
  posProduct   PosProduct @relation(fields: [posProductId], references: [id])
  shift        PosShift   @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([shiftId])
  @@index([posProductId])
  @@map("t_pos_void_log")
}

model Vendor {
  id          Int            @id @default(autoincrement()) @map("VENDOR_ID")
  code        String         @unique @map("VENDOR_CD") @db.VarChar(50)
  name        String         @map("NAMA_VENDOR") @db.VarChar(100)
  contactName String?        @map("NAMA_KONTAK") @db.VarChar(100)
  phone       String?        @map("NO_TELP") @db.VarChar(20)
  email       String?        @map("EMAIL") @db.VarChar(100)
  address     String?        @map("ALAMAT") @db.Text
  status      String         @default("ACTIVE") @map("STATUS") @db.VarChar(20)
  createdBy   String?        @map("CREATE_WHO") @db.VarChar(50)
  createdAt   DateTime       @default(now()) @map("CREATE_DATE")
  invoices    ApInvoice[]
  receipts    GoodsReceipt[]

  @@map("m_vendor")
}

model ApInvoice {
  id            Int           @id @default(autoincrement()) @map("INVOICE_ID")
  invoiceNumber String        @unique @map("INVOICE_NO") @db.VarChar(50)
  vendorId      Int           @map("VENDOR_ID")
  receiptId     Int?          @unique @map("RECEIPT_ID")
  invoiceDate   DateTime      @map("INVOICE_DATE") @db.Date
  dueDate       DateTime      @map("DUE_DATE") @db.Date
  totalAmount   Decimal       @map("TOTAL_AMOUNT") @db.Decimal(19, 4)
  paidAmount    Decimal       @default(0.0000) @map("PAID_AMOUNT") @db.Decimal(19, 4)
  status        String        @default("UNPAID") @map("STATUS") @db.VarChar(20)
  journalId     Int?          @map("JOURNAL_ID")
  createdBy     String?       @map("CREATE_WHO") @db.VarChar(50)
  createdAt     DateTime      @default(now()) @map("CREATE_DATE")
  receipt       GoodsReceipt? @relation(fields: [receiptId], references: [id])
  vendor        Vendor        @relation(fields: [vendorId], references: [id])
  payments      ApPayment[]

  @@index([vendorId])
  @@map("t_ap_invoice")
}

model ApPayment {
  id            Int       @id @default(autoincrement()) @map("PAYMENT_ID")
  paymentNumber String    @unique @map("PAYMENT_NO") @db.VarChar(50)
  invoiceId     Int       @map("INVOICE_ID")
  paymentDate   DateTime  @map("PAYMENT_DATE") @db.Date
  amount        Decimal   @map("AMOUNT") @db.Decimal(19, 4)
  paymentMethod String    @map("PAYMENT_METHOD") @db.VarChar(50)
  referenceNo   String?   @map("REFERENCE_NO") @db.VarChar(50)
  journalId     Int?      @map("JOURNAL_ID")
  createdBy     String?   @map("CREATE_WHO") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @map("CREATE_DATE")
  invoice       ApInvoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("t_ap_payment")
}

model Warehouse {
  id            Int                @id @default(autoincrement()) @map("WAREHOUSE_ID")
  code          String             @unique @map("WAREHOUSE_CD") @db.VarChar(50)
  name          String             @map("NAMA_GUDANG") @db.VarChar(100)
  address       String?            @map("ALAMAT") @db.Text
  isActive      Boolean            @default(true) @map("ACTIVE_FLAG")
  createdBy     String?            @map("CREATE_WHO") @db.VarChar(50)
  createdAt     DateTime           @default(now()) @map("CREATE_DATE")
  receipts      GoodsReceipt[]
  closings      InventoryClosing[]
  posShifts     PosShift[]
  adjustments   StockAdjustment[]
  transfersFrom StockTransfer[]    @relation("TransferFrom")
  transfersTo   StockTransfer[]    @relation("TransferTo")
  stocks        WarehouseStock[]

  @@map("m_warehouse")
}

model WarehouseStock {
  id              Int           @id @default(autoincrement()) @map("STOCK_ID")
  warehouseId     Int           @map("WAREHOUSE_ID")
  inventoryItemId Int           @map("INVENTORY_ITEM_ID")
  quantity        Decimal       @default(0.00) @map("QUANTITY") @db.Decimal(19, 2)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, inventoryItemId])
  @@index([warehouseId])
  @@index([inventoryItemId])
  @@map("t_warehouse_stock")
}

model StockTransfer {
  id              Int           @id @default(autoincrement()) @map("TRANSFER_ID")
  transferNumber  String        @unique @map("TRANSFER_NO") @db.VarChar(50)
  transferDate    DateTime      @map("TRANSFER_DATE") @db.Date
  fromWarehouseId Int           @map("FROM_WAREHOUSE_ID")
  toWarehouseId   Int           @map("TO_WAREHOUSE_ID")
  inventoryItemId Int           @map("INVENTORY_ITEM_ID")
  quantity        Decimal       @map("QUANTITY") @db.Decimal(19, 2)
  averageCost     Decimal       @default(0.0000) @map("AVERAGE_COST") @db.Decimal(19, 4)
  notes           String?       @map("NOTES") @db.Text
  status          String        @default("POSTED") @map("STATUS") @db.VarChar(20)
  journalId       Int?          @map("JOURNAL_ID")
  createdBy       String?       @map("CREATE_WHO") @db.VarChar(50)
  createdAt       DateTime      @default(now()) @map("CREATE_DATE")
  fromWarehouse   Warehouse     @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  toWarehouse     Warehouse     @relation("TransferTo", fields: [toWarehouseId], references: [id])

  @@index([transferDate])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([inventoryItemId])
  @@map("t_stock_transfer")
}

model InventoryClosing {
  id               Int           @id @default(autoincrement()) @map("CLOSING_ID")
  period           String        @map("PERIOD") @db.VarChar(7)
  warehouseId      Int           @map("WAREHOUSE_ID")
  inventoryItemId  Int           @map("INVENTORY_ITEM_ID")
  openingStock     Decimal       @default(0.00) @map("OPENING_STOCK") @db.Decimal(19, 2)
  receivingStock   Decimal       @default(0.00) @map("RECEIVING_STOCK") @db.Decimal(19, 2)
  transferInStock  Decimal       @default(0.00) @map("TRANSFER_IN_STOCK") @db.Decimal(19, 2)
  transferOutStock Decimal       @default(0.00) @map("TRANSFER_OUT_STOCK") @db.Decimal(19, 2)
  adjustmentStock  Decimal       @default(0.00) @map("ADJUSTMENT_STOCK") @db.Decimal(19, 2)
  salesStock       Decimal       @default(0.00) @map("SALES_STOCK") @db.Decimal(19, 2)
  endingStock      Decimal       @default(0.00) @map("ENDING_STOCK") @db.Decimal(19, 2)
  averageCost      Decimal       @default(0.0000) @map("AVERAGE_COST") @db.Decimal(19, 4)
  closedAt         DateTime      @default(now()) @map("CLOSED_AT")
  closedBy         String?       @map("CLOSED_BY") @db.VarChar(50)
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id])
  warehouse        Warehouse     @relation(fields: [warehouseId], references: [id])

  @@unique([period, warehouseId, inventoryItemId])
  @@index([period])
  @@index([warehouseId])
  @@index([inventoryItemId])
  @@map("t_inventory_closing")
}

enum InterUnitTransactionType {
  TRANSFER
  SERVICE
  ALLOCATION
}

enum InterUnitTransactionStatus {
  PENDING
  APPROVED
  POSTED
  ELIMINATED
}

enum BudgetPeriodStatus {
  DRAFT
  APPROVED
  ACTIVE
  CLOSED
}

enum AllocationMethod {
  EQUAL
  REVENUE
  HEADCOUNT
  AREA
  CUSTOM
}

enum AllocationExecutionStatus {
  PREVIEW
  EXECUTED
  ROLLED_BACK
}
